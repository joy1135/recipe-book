<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/primary_orange"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="32dp"
        android:paddingBottom="16dp">

        <!-- Language Selector -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_lang_en"
                android:layout_width="44dp"
                android:layout_height="32dp"
                android:text="EN"
                android:textSize="11sp"
                android:textStyle="bold"
                android:padding="0dp"
                android:layout_marginEnd="6dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button
                android:id="@+id/btn_lang_ru"
                android:layout_width="44dp"
                android:layout_height="32dp"
                android:text="RU"
                android:textSize="11sp"
                android:textStyle="bold"
                android:padding="0dp"
                android:layout_marginEnd="6dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button
                android:id="@+id/btn_lang_de"
                android:layout_width="44dp"
                android:layout_height="32dp"
                android:text="DE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:padding="0dp"
                style="@style/Widget.AppCompat.Button.Borderless"/>
        </LinearLayout>

        <!-- App Title -->
        <TextView
            android:id="@+id/tv_app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_app_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_subtitle"
            android:textColor="#FFECB3"
            android:textSize="14sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Filter Buttons -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="@android:color/white"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <Button
                android:id="@+id/btn_filter_all"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/all"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/btn_filter_bg"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button
                android:id="@+id/btn_filter_breakfast"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/breakfast"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/btn_filter_bg"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button
                android:id="@+id/btn_filter_lunch"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/lunch"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/btn_filter_bg"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <Button
                android:id="@+id/btn_filter_dinner"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/dinner"
                android:textSize="13sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/btn_filter_bg"
                style="@style/Widget.AppCompat.Button.Borderless"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Recipe List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_recipes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false"
        android:scrollbars="vertical"/>

</LinearLayout>
